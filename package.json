{
  "name": "can-i-eat-it",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "Can I Eat It V12 - advanced OCR, foreign menu translation, dietary compatibility, safe order mode, restaurant intelligence, community database, moderation, and multilingual server assistant.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "mobile:init": "cap init \"Can I Eat It\" com.darknigthmare.canieatit --web-dir dist",
    "mobile:add:android": "cap add android",
    "mobile:add:ios": "cap add ios",
    "mobile:sync": "npm run build && cap sync",
    "mobile:open:android": "cap open android",
    "mobile:open:ios": "cap open ios",
    "test": "vitest run",
    "test:watch": "vitest",
    "server": "node server/server.mjs",
    "dev:full": "node server/server.mjs & vite --host 0.0.0.0"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@tauri-apps/api": "^2.11.1",
    "tesseract.js": "^7.0.0",
    "@capacitor/camera": "^8.0.0",
    "better-sqlite3": "^12.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@tauri-apps/cli": "^2.11.4",
    "typescript": "^5.8.3",
    "vite": "^8.1.3",
    "vitest": "^3.2.0"
  }
}
